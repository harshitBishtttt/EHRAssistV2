# FHIR / VHA API
# Use HTTPS for FHIR API (true) or HTTP (false)
VITE_FHIR_USE_HTTPS=true

# Full FHIR base URL (optional - overrides protocol if VITE_FHIR_USE_HTTPS is set)
# Example: https://fhirassist.rsystems.com:481
VITE_FHIR_BASE=https://fhirassist.rsystems.com:481

# Optional: custom paths if certs are elsewhere (certs required in ./certs/)
# VITE_SSL_KEY_PATH=./certs/fhirassist_nopass.key
# VITE_SSL_CERT_PATH=./certs/fhirassist.crt
